---
import Footer from '../components/Footer.astro';
import FloatingActions from '../components/FloatingActions.astro';
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'JAES Cargo | Casilleros internacionales y correo especializado',
	description = 'Soluciones de casillero virtual, courier, exportaciones, personal shopper y correo especializado.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/logo-circular.svg" />
		<link rel="icon" href="/logo-circular.ico" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;800&family=Open+Sans:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="m-0 min-h-full w-full overflow-x-hidden bg-white font-body text-secondary">
		<slot />
		<Footer />
		<FloatingActions />
	</body>
</html>
