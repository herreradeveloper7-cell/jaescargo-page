---
import { ChevronDown, PackageCheck, PackagePlus, Plane, ShoppingBag } from '@lucide/astro';

const registerUrl = 'https://wolfbox.app/register';

const navItems = [
	{ label: 'Inicio', href: '/' },
	{ label: 'Nosotros', href: '/nosotros' },
	{ label: 'Contacto', href: '/contacto' },
];

const serviceItems = [
	{ label: 'Casillero virtual', href: '/servicios#casillero', Icon: PackageCheck },
	{ label: 'Exportaciones', href: '/servicios#exportaciones', Icon: Plane },
	{ label: 'Personal shopper', href: '/servicios#shopper', Icon: ShoppingBag },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const isActive = (href: string) => {
	if (href.includes('#')) return false;
	const path = href.split('#')[0].replace(/\/$/, '') || '/';
	return currentPath === path;
};

const containerClass = 'mx-auto w-full max-w-[1180px] px-6 max-[760px]:px-[18px]';
const navLinkClass =
	"relative inline-flex min-h-12 items-center whitespace-nowrap px-0.5 font-heading text-[clamp(0.84rem,0.82vw,0.94rem)] font-bold text-secondary no-underline transition-[color,transform] duration-[180ms] after:absolute after:bottom-1 after:left-1/2 after:h-0.5 after:w-full after:-translate-x-1/2 after:scale-x-0 after:rounded-full after:bg-primary after:transition-transform after:duration-[220ms] hover:-translate-y-px hover:text-primary hover:after:scale-x-100 max-[1440px]:min-h-10 max-[1440px]:text-[0.82rem]";
const navLinkActiveClass = 'text-primary after:scale-x-100';
const servicesActive = currentPath === '/servicios' || currentPath === '/personal-shopper';
---

<header class="sticky top-0 z-20 border-b border-border bg-white shadow-[0_14px_36px_rgba(45,45,45,0.08)]">
	<div
		class={`${containerClass} grid min-h-[108px] grid-cols-[max-content_minmax(0,1fr)_max-content] items-center gap-[clamp(24px,3vw,44px)] max-[1440px]:min-h-[86px] max-[1440px]:gap-[clamp(20px,2.4vw,34px)] max-[980px]:min-h-0 max-[980px]:grid-cols-[max-content_max-content] max-[980px]:justify-between max-[980px]:gap-[18px] max-[980px]:py-[18px] max-[620px]:grid-cols-1`}
	>
		<a class="inline-flex w-fit items-center justify-self-start leading-none no-underline" href="/" aria-label="JAES Cargo inicio">
			<img class="h-[92px] w-auto object-contain max-[1440px]:h-[76px] max-[980px]:h-[82px] max-[620px]:h-[70px]" src="/images/logo-horizontal-red.webp" alt="JAES Cargo" width="214" height="92" />
		</a>

		<nav
			class="flex min-w-0 items-center justify-center gap-[clamp(16px,2vw,32px)] max-[1440px]:gap-[clamp(14px,1.7vw,24px)] max-[980px]:col-span-full max-[980px]:row-start-2 max-[980px]:justify-start max-[980px]:overflow-x-auto max-[980px]:pb-2"
			aria-label="Navegacion principal"
		>
			<a class:list={[navLinkClass, { [navLinkActiveClass]: isActive('/') }]} href="/">
				Inicio
			</a>

			<div class="group/services relative">
				<a
					class:list={[
						`${navLinkClass} gap-1.5`,
						{ [navLinkActiveClass]: servicesActive },
					]}
					href="/servicios"
					aria-haspopup="true"
				>
					Servicios
					<ChevronDown
						class="transition-transform duration-200 group-hover/services:rotate-180 group-focus-within/services:rotate-180"
						size={16}
						stroke-width={2.5}
						aria-hidden="true"
					/>
				</a>

				<div class="pointer-events-none absolute left-1/2 top-full z-30 min-w-[230px] -translate-x-1/2 translate-y-3 rounded-lg border border-border bg-white p-2 opacity-0 shadow-[0_20px_46px_rgba(45,45,45,0.14)] transition-[opacity,transform] duration-200 group-hover/services:pointer-events-auto group-hover/services:translate-y-1.5 group-hover/services:opacity-100 group-focus-within/services:pointer-events-auto group-focus-within/services:translate-y-1.5 group-focus-within/services:opacity-100 max-[980px]:left-0 max-[980px]:translate-x-0">
					<div class="absolute -top-3 left-0 h-3 w-full" aria-hidden="true"></div>
					{
						serviceItems.map(({ label, href, Icon }) => (
							<a
								class="group/item grid grid-cols-[34px_1fr_auto] items-center gap-3 rounded-md px-3.5 py-3 font-heading text-[0.88rem] font-bold text-secondary no-underline transition-[background,color,transform] duration-180 hover:translate-x-0.5 hover:bg-surface hover:text-primary"
								href={href}
							>
								<span class="inline-flex h-[34px] w-[34px] items-center justify-center rounded-full border border-border bg-white text-primary shadow-[0_8px_18px_rgba(139,0,0,0.08)] transition-[background,border-color,transform] duration-180 group-hover/item:scale-105 group-hover/item:border-primary/30 group-hover/item:bg-white">
									<Icon size={18} stroke-width={2.3} aria-hidden="true" />
								</span>
								<span>{label}</span>
								<span class="h-1.5 w-1.5 rounded-full bg-primary opacity-0 transition-opacity duration-180 group-hover/item:opacity-100"></span>
							</a>
						))
					}
				</div>
			</div>

			{
				navItems.slice(1).map((item) => (
					<a class:list={[navLinkClass, { [navLinkActiveClass]: isActive(item.href) }]} href={item.href}>
						{item.label}
					</a>
				))
			}
		</nav>

		<div class="flex items-center justify-end max-[620px]:justify-start">
			<a
				class="group relative inline-flex min-h-[54px] items-center justify-center gap-2.5 overflow-hidden whitespace-nowrap rounded-md border border-primary bg-[linear-gradient(135deg,rgba(255,255,255,0.16),transparent_36%)] bg-primary px-[26px] py-3.5 font-heading text-[0.9rem] font-bold text-white no-underline shadow-[0_14px_28px_rgba(139,0,0,0.22),inset_0_1px_0_rgba(255,255,255,0.18)] transition-[border-color,box-shadow,transform] duration-[180ms] before:absolute before:inset-0 before:-translate-x-[120%] before:bg-[linear-gradient(90deg,transparent,rgba(255,255,255,0.36),transparent)] before:transition-transform before:duration-[420ms] hover:-translate-y-0.5 hover:border-primary hover:bg-[linear-gradient(135deg,rgba(255,255,255,0.2),transparent_38%)] hover:bg-primary hover:shadow-[0_18px_34px_rgba(139,0,0,0.28),0_0_0_4px_rgba(139,0,0,0.08),0_0_24px_rgba(139,0,0,0.18),inset_0_1px_0_rgba(255,255,255,0.22)] hover:before:translate-x-[120%] max-[1440px]:min-h-[46px] max-[1440px]:px-5 max-[1440px]:py-2.5 max-[1440px]:text-[0.82rem] max-[620px]:w-full"
				href={registerUrl}
			>
				<span class="relative z-10">Crear casillero</span>
				<PackagePlus class="relative z-10 shrink-0 transition-transform duration-[180ms] group-hover:translate-x-0.5 group-hover:-rotate-4" size={19} stroke-width={2.4} aria-hidden="true" />
			</a>
		</div>
	</div>
</header>
