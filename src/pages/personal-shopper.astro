---
import Header from '../components/Header.astro';
import Layout from '../layouts/Layout.astro';
import CtaSection from '../components/CtaSection.astro';

const containerClass = 'mx-auto w-full max-w-[1180px] px-6 max-[760px]:px-[18px]';
const buttonPrimary =
	'inline-flex min-h-[46px] items-center justify-center rounded-md border border-primary bg-primary px-[18px] py-3 font-heading text-[0.9rem] font-bold text-white no-underline transition-[background,border-color,color,transform] duration-[180ms] hover:-translate-y-px hover:bg-primary-dark';
---

<Layout
	title="Personal Shopper | JAES Cargo"
	description="Asistencia de compra internacional para productos, pagos y coordinacion de envio."
>
	<Header />
	<main>
		<section class="py-24 max-[760px]:py-16">
			<div class={`${containerClass} grid grid-cols-[1.1fr_0.9fr] items-center gap-12 max-[820px]:grid-cols-1`}>
				<div>
					<span class="font-heading text-[0.78rem] font-extrabold uppercase tracking-[0.08em] text-primary">
						Personal shopper
					</span>
					<h1 class="mt-3 font-heading text-[clamp(2rem,3.9vw,3.55rem)] font-extrabold leading-[1.08] text-secondary">
						Compras internacionales asistidas cuando necesitas una mano experta.
					</h1>
					<p class="my-5 mb-[30px] max-w-[680px] text-[1.06rem] leading-[1.7] text-muted">
						Te ayudamos a cotizar, comprar y coordinar productos en tiendas internacionales para
						que el proceso sea mas simple, seguro y trazable.
					</p>
					<a class={buttonPrimary} href="https://wolfbox.app/register">Crear casillero</a>
				</div>
				<ul class="m-0 grid list-none gap-[18px] rounded-lg bg-secondary p-[34px] text-white">
					<li class="border-b border-white/20 pb-[18px]">Cotizacion de productos y disponibilidad.</li>
					<li class="border-b border-white/20 pb-[18px]">Asistencia con pagos o tiendas internacionales.</li>
					<li class="border-b border-white/20 pb-[18px]">Coordinacion con casillero y envio final.</li>
					<li>Acompañamiento durante el proceso de compra.</li>
				</ul>
			</div>
		</section>
		<CtaSection />
	</main>
</Layout>
