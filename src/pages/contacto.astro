---
import {
	ArrowRight,
	ClipboardList,
	Mail,
	MapPin,
	MessageCircle,
	PackageCheck,
	Phone,
	Send,
	User,
} from '@lucide/astro';
import Header from '../components/Header.astro';
import Layout from '../layouts/Layout.astro';

const containerClass = 'mx-auto w-full max-w-[1180px] px-6 max-[760px]:px-[18px]';
const inputClass =
	'w-full rounded-lg border border-border bg-white px-4 py-3.5 font-body text-[0.95rem] text-secondary outline-none shadow-[0_10px_24px_rgba(45,45,45,0.04)] transition-[border-color,box-shadow,transform] duration-200 placeholder:text-muted/70 focus:-translate-y-0.5 focus:border-primary/55 focus:shadow-[0_16px_34px_rgba(45,45,45,0.08),0_0_0_4px_rgba(139,0,0,0.08)]';
const labelClass = 'mb-2 block font-heading text-[0.8rem] font-extrabold uppercase tracking-[0.06em] text-secondary';
const fieldIconClass =
	'pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-primary/80';
const buttonClass =
	'group relative inline-flex min-h-12 w-full items-center justify-center gap-2.5 overflow-hidden rounded-lg border border-primary bg-[linear-gradient(135deg,rgba(255,255,255,0.14),transparent_34%)] bg-primary px-5 py-3 font-heading text-[0.9rem] font-extrabold text-white no-underline shadow-[0_16px_34px_rgba(139,0,0,0.22),inset_0_1px_0_rgba(255,255,255,0.18)] transition-[border-color,box-shadow,transform] duration-[180ms] before:absolute before:inset-0 before:-translate-x-[120%] before:bg-[linear-gradient(90deg,transparent,rgba(255,255,255,0.3),transparent)] before:transition-transform before:duration-[420ms] hover:-translate-y-0.5 hover:border-primary hover:shadow-[0_20px_42px_rgba(139,0,0,0.28),0_0_0_4px_rgba(139,0,0,0.08),inset_0_1px_0_rgba(255,255,255,0.22)] hover:before:translate-x-[120%]';
const infoCardClass =
	'translate-x-[-26px] translate-y-3 rounded-lg border border-border bg-white p-5 opacity-0 shadow-[0_18px_42px_rgba(45,45,45,0.07)] transition-[opacity,border-color,box-shadow,transform] duration-[760ms] ease-out [&.is-visible]:translate-x-0 [&.is-visible]:translate-y-0 [&.is-visible]:opacity-100 [&.is-visible]:animate-fade-in-left [&.is-visible]:animate-duration-[760ms] [&.is-visible]:animate-fill-mode-both [&.is-visible]:animate-bezier-quart-out hover:-translate-y-1 hover:border-primary/25 hover:shadow-[0_24px_54px_rgba(45,45,45,0.11),0_0_0_1px_rgba(139,0,0,0.08)]';
---

<Layout
	title="Contacto | JAES Cargo"
	description="Contacta a JAES Cargo para cotizar envíos, resolver dudas sobre casillero virtual, courier, exportaciones y personal shopper."
>
	<Header />
	<main>
		<section class="bg-[linear-gradient(90deg,rgba(255,255,255,0.95)_0%,rgba(255,255,255,0.84)_58%,rgba(255,255,255,0.36)_100%),url('/images/contact_hero.webp')] bg-cover bg-center py-[72px] pb-[60px] max-[760px]:bg-[linear-gradient(90deg,rgba(255,255,255,0.95)_0%,rgba(255,255,255,0.88)_100%),url('/images/contact_hero.webp')] max-[760px]:py-14">
			<div class={containerClass}>
				<span class="font-heading text-[0.78rem] font-extrabold uppercase tracking-[0.08em] text-primary">
					Contacto
				</span>
				<h1 class="mt-3 max-w-[700px] font-heading text-[clamp(2rem,3.9vw,3.55rem)] font-extrabold leading-[1.08] text-secondary">
					Cotiza, pregunta y recibe <span class="text-primary">acompañamiento claro</span>.
				</h1>
				<span class="mt-5 block h-[3px] w-[72px] rounded-full bg-primary"></span>
				<p class="mt-[18px] max-w-[680px] text-[1.04rem] leading-[1.7] text-muted">
					Envíanos tus datos y generaremos un mensaje directo para WhatsApp con la información necesaria para orientarte mejor.
				</p>
			</div>
		</section>

		<section class="bg-surface py-[72px] max-[760px]:py-14">
			<div class={`${containerClass} grid items-start gap-10 lg:grid-cols-[0.9fr_1.1fr]`}>
				<div class="max-w-[520px]">
					<span class="font-heading text-[0.78rem] font-extrabold uppercase tracking-[0.08em] text-primary">
						Estamos listos para ayudarte
					</span>
					<h2 class="mt-2 font-heading text-[clamp(1.7rem,2.6vw,2.7rem)] font-extrabold leading-[1.1] text-secondary">
						Hablemos de tu envío.
					</h2>
					<span class="mt-5 block h-[3px] w-[64px] rounded-full bg-primary"></span>
					<p class="mt-5 text-[1rem] leading-[1.75] text-muted">
						Completa el formulario y al enviarlo se abrirá WhatsApp con un mensaje organizado para nuestro equipo. Así podremos responderte con mayor claridad.
					</p>

					<div class="mt-8 grid gap-4">
						<article class={infoCardClass} data-contact-info-card>
							<div class="flex items-start gap-4">
								<span class="inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-full border border-primary/15 bg-white text-primary shadow-[0_10px_24px_rgba(139,0,0,0.08)]">
									<MessageCircle size={22} stroke-width={2.3} aria-hidden="true" />
								</span>
								<div>
									<h3 class="font-heading text-[1rem] font-extrabold text-primary">Atención por WhatsApp</h3>
									<p class="mt-1 text-[0.94rem] leading-[1.65] text-muted">
										Recibe orientación para casillero virtual, courier, compras y exportaciones.
									</p>
								</div>
							</div>
						</article>

						<article class={infoCardClass} data-contact-info-card>
							<div class="flex items-start gap-4">
								<span class="inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-full border border-primary/15 bg-white text-primary shadow-[0_10px_24px_rgba(139,0,0,0.08)]">
									<PackageCheck size={22} stroke-width={2.3} aria-hidden="true" />
								</span>
								<div>
									<h3 class="font-heading text-[1rem] font-extrabold text-primary">Información precisa</h3>
									<p class="mt-1 text-[0.94rem] leading-[1.65] text-muted">
										Cuéntanos origen, destino, tipo de servicio y detalles del paquete.
									</p>
								</div>
							</div>
						</article>
					</div>
				</div>

				<div
					class="group/contact-form translate-y-10 scale-[0.98] opacity-0 transition-[opacity,transform] duration-[900ms] ease-out [&.is-visible]:translate-y-0 [&.is-visible]:scale-100 [&.is-visible]:opacity-100 [&.is-visible]:animate-blurred-fade-in [&.is-visible]:animate-duration-[900ms] [&.is-visible]:animate-fill-mode-both [&.is-visible]:animate-bezier-quart-out"
					data-contact-card
				>
					<form
						class="relative overflow-hidden rounded-lg border border-border bg-white p-7 shadow-[0_28px_74px_rgba(45,45,45,0.13)] before:absolute before:inset-x-0 before:top-0 before:h-1 before:bg-[linear-gradient(90deg,var(--color-primary),var(--color-secondary),var(--color-primary))] max-[560px]:p-5"
						data-contact-form
					>
						<div class="relative z-10">
							<div class="flex items-start justify-between gap-5 max-[560px]:flex-col">
								<div>
									<span class="font-heading text-[0.74rem] font-extrabold uppercase tracking-[0.08em] text-primary">
										Formulario directo
									</span>
									<h2 class="mt-2 font-heading text-[clamp(1.45rem,2.4vw,2.2rem)] font-extrabold leading-[1.12] text-secondary">
										Cuéntanos qué necesitas.
									</h2>
								</div>
								<span class="inline-flex h-14 w-14 shrink-0 items-center justify-center rounded-full border border-primary/15 bg-surface text-primary shadow-[0_14px_30px_rgba(139,0,0,0.1)] group-[.is-visible]/contact-form:animate-float group-[.is-visible]/contact-form:animate-duration-[3600ms] group-[.is-visible]/contact-form:animate-iteration-count-infinite group-[.is-visible]/contact-form:animate-ease-in-out">
									<ClipboardList size={25} stroke-width={2.2} aria-hidden="true" />
								</span>
							</div>

							<div class="mt-7 grid gap-5 sm:grid-cols-2">
								<label>
									<span class={labelClass}>Nombre</span>
									<div class="relative">
										<User class={fieldIconClass} size={18} stroke-width={2.2} aria-hidden="true" />
										<input class={`${inputClass} pl-11`} type="text" name="nombre" placeholder="Tu nombre completo" required />
									</div>
								</label>

								<label>
									<span class={labelClass}>WhatsApp</span>
									<div class="relative">
										<Phone class={fieldIconClass} size={18} stroke-width={2.2} aria-hidden="true" />
										<input class={`${inputClass} pl-11`} type="tel" name="telefono" placeholder="+57 300 000 0000" required />
									</div>
								</label>

								<label>
									<span class={labelClass}>Correo</span>
									<div class="relative">
										<Mail class={fieldIconClass} size={18} stroke-width={2.2} aria-hidden="true" />
										<input class={`${inputClass} pl-11`} type="email" name="correo" placeholder="correo@ejemplo.com" />
									</div>
								</label>

								<label>
									<span class={labelClass}>Ciudad</span>
									<div class="relative">
										<MapPin class={fieldIconClass} size={18} stroke-width={2.2} aria-hidden="true" />
										<input class={`${inputClass} pl-11`} type="text" name="ciudad" placeholder="Ciudad / País" />
									</div>
								</label>

								<label class="sm:col-span-2">
									<span class={labelClass}>Servicio de interés</span>
									<select class={inputClass} name="servicio" required>
										<option value="">Selecciona un servicio</option>
										<option>Casillero virtual</option>
										<option>Courier y documentos</option>
										<option>Exportaciones</option>
										<option>Personal shopper</option>
										<option>Asesoría general</option>
									</select>
								</label>

								<label class="sm:col-span-2">
									<span class={labelClass}>Mensaje</span>
									<textarea
										class={`${inputClass} min-h-[132px] resize-y`}
										name="mensaje"
										placeholder="Cuéntanos qué quieres enviar, comprar o consultar."
										required
									></textarea>
								</label>
							</div>

							<div class="mt-6 grid items-center gap-4 sm:grid-cols-[1fr_auto]">
								<p class="text-[0.86rem] leading-[1.6] text-muted" data-contact-status>
									Tus datos se usarán únicamente para armar el mensaje de WhatsApp.
								</p>
								<button class={buttonClass} type="submit">
									<span class="relative z-10">Enviar por WhatsApp</span>
									<Send class="relative z-10 transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" size={18} stroke-width={2.4} aria-hidden="true" />
								</button>
							</div>
						</div>
					</form>
				</div>
			</div>
		</section>
	</main>
</Layout>

<script>
	const contactCard = document.querySelector('[data-contact-card]');
	const infoCards = Array.from(document.querySelectorAll('[data-contact-info-card]'));
	const contactForm = document.querySelector<HTMLFormElement>('[data-contact-form]');
	const contactStatus = document.querySelector<HTMLElement>('[data-contact-status]');

	if (contactCard) {
		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (!entry.isIntersecting) return;
					entry.target.classList.add('is-visible');
					observer.unobserve(entry.target);
				});
			},
			{ threshold: 0.26, rootMargin: '0px 0px -8% 0px' },
		);

		observer.observe(contactCard);
	}

	if (infoCards.length) {
		const infoObserver = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (!entry.isIntersecting) return;
					infoCards.forEach((card, index) => {
						window.setTimeout(() => {
							card.classList.add('is-visible');
						}, index * 160);
					});
					infoObserver.disconnect();
				});
			},
			{ threshold: 0.3, rootMargin: '0px 0px -10% 0px' },
		);

		infoObserver.observe(infoCards[0]);
	}

	if (contactForm) {
		contactForm.addEventListener('submit', (event) => {
			event.preventDefault();

			const formData = new FormData(contactForm);
			const getValue = (field: string) => String(formData.get(field) || '').trim();

			const nombre = getValue('nombre');
			const telefono = getValue('telefono');
			const correo = getValue('correo');
			const ciudad = getValue('ciudad');
			const servicio = getValue('servicio');
			const mensaje = getValue('mensaje');

			if (!nombre || !telefono || !servicio || !mensaje) {
				if (contactStatus) {
					contactStatus.textContent = 'Por favor completa nombre, WhatsApp, servicio y mensaje.';
					contactStatus.classList.remove('text-muted');
					contactStatus.classList.add('text-primary');
				}
				return;
			}

			const whatsappMessage = [
				'Hola JAES Cargo, quiero solicitar información.',
				'',
				`Nombre: ${nombre}`,
				`WhatsApp: ${telefono}`,
				correo ? `Correo: ${correo}` : '',
				ciudad ? `Ciudad: ${ciudad}` : '',
				`Servicio de interés: ${servicio}`,
				'',
				`Mensaje: ${mensaje}`,
			]
				.filter(Boolean)
				.join('\n');

			const whatsappUrl = `https://wa.me/?text=${encodeURIComponent(whatsappMessage)}`;
			window.open(whatsappUrl, '_blank', 'noopener,noreferrer');

			if (contactStatus) {
				contactStatus.textContent = 'Mensaje generado. WhatsApp se abrirá en una nueva pestaña.';
				contactStatus.classList.remove('text-muted');
				contactStatus.classList.add('text-primary');
			}
		});
	}
</script>
